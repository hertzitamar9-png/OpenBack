# SSH Configuration
SSH_KEY=~/.ssh/your-ssh-key

# Docker Configuration
GHCR_USERNAME=username
GHCR_REPO=your-repo-name
GHCR_TOKEN=your_docker_token_here

DOMAIN=your-domain.com

# API Key
API_KEY=your_api_key_here

# Public origin where the SPA and auth endpoints live. OpenBack is
# self-contained, so auth is served from this origin (no separate api.
# subdomain). In dev set this to http://localhost:9000 (the Vite origin).
# If unset, it defaults to https://${DOMAIN}.
AUTH_ORIGIN=

# Pin a stable Ed25519 private JWK (JSON) so logins survive restarts. If
# unset, an ephemeral key is generated at startup (logins reset on restart).
AUTH_PRIVATE_JWK=

# Optional Google OAuth (leave unset to hide the Google sign-in button).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional SMTP for sending login codes by email. If unset, the code is
# logged to the server console (and shown in dev) instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@openback.app
AUTH_DATA_DIR=/tmp

# Optional CDN origin (e.g. https://cdn.example.com) prepended to hashed asset
# URLs from asset-manifest.json. Leave empty to serve assets from the same
# origin as the app. No trailing slash.
CDN_BASE=

# Server Hosts
SERVER_HOST_STAGING=123.456.78.90
SERVER_HOST_NBG1=123.456.78.92

# Version
VERSION_TAG="latest"
