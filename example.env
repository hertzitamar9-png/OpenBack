# SSH Configuration
SSH_KEY=~/.ssh/your-ssh-key

# Docker Configuration
GHCR_USERNAME=username
GHCR_REPO=your-repo-name
GHCR_TOKEN=your_docker_token_here

# Bare hostname (no protocol). E.g. openback-cbe3.onrender.com — NOT
# https://....  Used internally to build origins. Must be set.
DOMAIN=openback-cbe3.onrender.com

# API Key
API_KEY=your_api_key_here

# Public origin where the SPA and auth endpoints live. OpenBack is
# self-contained, so auth is served from this origin (no separate api.
# subdomain). In dev set this to http://localhost:9000 (the Vite origin).
# If unset, it defaults to https://${DOMAIN}.
AUTH_ORIGIN=https://openback-cbe3.onrender.com

# Pin a stable Ed25519 private JWK (JSON) so logins survive restarts. If
# unset, an ephemeral key is generated at startup (logins reset on restart).
# Get one by starting the server once in dev — it prints the JWK to console.
AUTH_PRIVATE_JWK=

# Optional Google OAuth (leave unset to hide the Google sign-in button).
# Create a project at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; defaults to AUTH_ORIGIN + /auth/google/callback
GOOGLE_REDIRECT_URI=

# Recommended on Render: Brevo's HTTPS API. Render Free blocks outbound SMTP
# ports, but HTTPS works. Register and verify BREVO_SENDER_EMAIL in Brevo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=OpenBack

# SMTP fallback for hosts that allow outbound SMTP. Render Free does not.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@openback.app
# Required in staging and production. On Render, link a PostgreSQL database
# and expose its internal connection URL under this exact environment name.
DATABASE_URL=
# Development-only file fallback. Do not use /tmp for deployed accounts.
AUTH_DATA_DIR=/tmp

# Optional CDN origin (e.g. https://cdn.example.com) prepended to hashed asset
# URLs from asset-manifest.json. Leave empty to serve assets from the same
# origin as the app. No trailing slash.
CDN_BASE=

# Optional external URL for cosmetics/privileges data (cosmetics.json,
# profane_words_game_server, reserved_clan_tags). When unset, the privilege
# checker is skipped and the server falls back to permissive defaults.
# Only needed if you have a separate API serving this data.
COSMETICS_BASE_URL=

# Optional matchmaking API base URL. When unset, matchmaking polling is
# skipped entirely. Only needed if you run a matchmaking service.
MATCHMAKING_API_URL=

# Server Hosts
SERVER_HOST_STAGING=123.456.78.90
SERVER_HOST_NBG1=123.456.78.92

# Version
VERSION_TAG="latest"
